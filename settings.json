{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:20128/v1",
    "ANTHROPIC_CUSTOM_MODEL_OPTION": "star",
    "ANTHROPIC_CUSTOM_MODEL_OPTION_NAME": "OmniRoute UA",
    "GITHUB_TOKEN": "YOUR_GITHUB_TOKEN",
    "ANTHROPIC_API_KEY": "YOUR_API_KEY"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "star",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const data=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(data.tool_response?.filePath || data.tool_input?.file_path || '')\" | { read -r f; if [[ -n \"$f\" && \"$f\" =~ \\.(js|jsx|ts|tsx|json|css|scss|html|md|yml|yaml)$ ]]; then prettier --write \"$f\" 2>/dev/null || true; fi; }",
            "statusMessage": "Форматирование кода..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
